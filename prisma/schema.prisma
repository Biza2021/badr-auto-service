generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TECHNICIAN
}

enum RepairStatus {
  RECEPTION
  DIAGNOSTIC
  ATTENTE_ACCORD_CLIENT
  ATTENTE_PIECES
  EN_REPARATION
  CONTROLE_QUALITE
  PRET_A_RECUPERER
  LIVRE
  ANNULE
}

enum AppointmentStatus {
  EN_ATTENTE
  CONFIRME
  EN_COURS
  TERMINE
  ANNULE
}

enum PaymentStatus {
  NON_PAYE
  PARTIELLEMENT_PAYE
  PAYE
}

enum InvoiceLineType {
  SERVICE
  PIECE
  MAIN_OEUVRE
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  phone        String?
  role         UserRole      @default(ADMIN)
  passwordHash String
  repairs      Repair[]      @relation("RepairTechnician")
  activities   ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Customer {
  id           String        @id @default(cuid())
  fullName     String
  phone        String
  email        String?
  notes        String?
  vehicles     Vehicle[]
  repairs      Repair[]
  appointments Appointment[]
  invoices     Invoice[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([fullName])
  @@index([phone])
}

model Vehicle {
  id           String        @id @default(cuid())
  customerId   String
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  brand        String
  model        String
  year         Int?
  licensePlate String?
  mileage      Int?
  repairs      Repair[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([licensePlate])
}

model Repair {
  id                  String        @id @default(cuid())
  trackingCode        String        @unique
  customerId          String
  customer            Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId           String?
  vehicle             Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  technicianId        String?
  technician          User?         @relation("RepairTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  issue               String
  status              RepairStatus  @default(RECEPTION)
  estimatedPrice      Decimal?      @db.Decimal(10, 2)
  estimatedCompletion DateTime?
  internalNotes       String?
  customerNotes       String?
  deliveredAt         DateTime?
  invoice             Invoice?
  activities          ActivityLog[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Appointment {
  id                 String            @id @default(cuid())
  customerId         String?
  customer           Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vehicleId          String?
  vehicle            Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  fullName           String
  phone              String
  vehicleText        String
  licensePlate       String?
  desiredDateTime    DateTime
  serviceType        String
  problemDescription String
  notes              String?
  status             AppointmentStatus @default(EN_ATTENTE)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([desiredDateTime])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  repairId      String        @unique
  repair        Repair        @relation(fields: [repairId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lines         InvoiceLine[]
  totalAmount   Decimal       @db.Decimal(10, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(10, 2)
  status        PaymentStatus @default(NON_PAYE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceLine {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type        InvoiceLineType
  description String
  quantity    Int             @default(1)
  unitPrice   Decimal         @db.Decimal(10, 2)
  createdAt   DateTime        @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  repairId   String?
  repair     Repair?  @relation(fields: [repairId], references: [id], onDelete: SetNull)
  message    String
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model GarageSettings {
  id              String   @id @default(cuid())
  singletonKey    String   @unique @default("default")
  garageName      String   @default("Badr Auto Service")
  phoneNumber     String
  whatsappNumber  String
  address         String
  openingHours    String
  defaultLanguage String   @default("fr")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
